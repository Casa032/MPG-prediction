Private Sub Worksheet_Change(ByVal Target As Range)

   
    Dim plageCible As Range
    Set plageCible = Range("H2:H1000")
    Dim separateur As String
    separateur = ", "
    

    If Intersect(Target, plageCible) Is Nothing Then Exit Sub
    If Target.Cells.Count > 1 Then Exit Sub
    If Target.Value = "" Then Exit Sub

    Application.EnableEvents = False
    On Error GoTo Nettoyage

    Dim nouvelleValeur As String
    Dim valeurActuelle As String
    Dim valeurFinale As String

    nouvelleValeur = Target.Value
    Application.Undo
    valeurActuelle = Target.Value

    If valeurActuelle = "" Then
        valeurFinale = nouvelleValeur
    ElseIf InStr(separateur & valeurActuelle & separateur, separateur & nouvelleValeur & separateur) > 0 Then
        valeurFinale = valeurActuelle
        valeurFinale = Replace(valeurFinale, nouvelleValeur & separateur, "")
        valeurFinale = Replace(valeurFinale, separateur & nouvelleValeur, "")
        valeurFinale = Replace(valeurFinale, nouvelleValeur, "")
    Else
        valeurFinale = valeurActuelle & separateur & nouvelleValeur
    End If

    Target.Value = valeurFinale

Nettoyage:
    Application.EnableEvents = True

End Sub


//dans un module séparé
Sub CreerListeDeroulante()

   
    Dim maListe As String
    maListe = "Cofidis GROUP,Cofidis France, Cofidis Belgique, Cofidis Espagne, Synergie, Monabanq, Créatis"
   

    Dim ws As Worksheet
    Set ws = ThisWorkbook.Sheets("Referentiel")

    With ws.Range("H2:H1000").Validation
        .Delete
        .Add Type:=xlValidateList, _
             AlertStyle:=xlValidAlertStop, _
             Formula1:=maListe
        .InCellDropdown = True
    End With




End Sub
