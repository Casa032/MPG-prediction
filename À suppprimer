Sub CreerListeDeroulante()

   
    Dim maListe As String
    maListe = "Cofidis GROUP,Cofidis France, Cofidis Belgique, Cofidis Espagne, Synergie, Monabanq, Créatis"
   

    Dim ws As Worksheet
    Set ws = ThisWorkbook.Sheets("Referentiel")

    With ws.Range("H2:H1000").Validation
        .Delete
        .Add Type:=xlValidateList, _
             AlertStyle:=xlValidAlertStop, _
             Formula1:=maListe
        .InCellDropdown = True
    End With




End Sub
