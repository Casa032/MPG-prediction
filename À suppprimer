Sub CreerListeDeroulante()

    ' === VOTRE LISTE ICI ===
    Dim maListe As String
    maListe = "Paris,Lyon,Marseille,Bordeaux,Toulouse,Nantes,Strasbourg,Nice"
    ' ← Modifiez uniquement cette ligne
    ' =======================

    Dim ws As Worksheet
    Set ws = ThisWorkbook.Sheets("Feuil1")  ' ← Nom de votre feuille

    With ws.Range("B2:B1000").Validation
        .Delete
        .Add Type:=xlValidateList, _
             AlertStyle:=xlValidAlertStop, _
             Formula1:=maListe
        .ShowDropDown = False
        .InCellDropdown = True
    End With

    MsgBox "Liste déroulante créée sur B2:B1000 !"

End Sub

