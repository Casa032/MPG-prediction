Private Function EstFormatValide(valeur As String) As Boolean
    Dim parties() As String
    Dim dateParts() As String
    
    If InStr(valeur, ":") = 0 Then Exit Function
    parties = Split(valeur, ":", 2)
    
    ' Vérifie strictement dd/mm/yyyy avec Split
    If InStr(parties(0), "/") = 0 Then Exit Function
    dateParts = Split(Trim(parties(0)), "/")
    
    If UBound(dateParts) <> 2 Then Exit Function
    If Len(dateParts(0)) <> 2 Then Exit Function
    If Len(dateParts(1)) <> 2 Then Exit Function
    If Len(dateParts(2)) <> 4 Then Exit Function
    If Not IsNumeric(dateParts(0)) Then Exit Function
    If Not IsNumeric(dateParts(1)) Then Exit Function
    If Not IsNumeric(dateParts(2)) Then Exit Function
    If CInt(dateParts(0)) < 1 Or CInt(dateParts(0)) > 31 Then Exit Function
    If CInt(dateParts(1)) < 1 Or CInt(dateParts(1)) > 12 Then Exit Function
    If Trim(parties(1)) = "" Then Exit Function
    
    EstFormatValide = True
End Function




If Not Intersect(Target, Range("M:M")) Is Nothing Then
    If Target.Cells.Count = 1 And Target.Value <> "" Then
        Application.EnableEvents = False
        On Error GoTo Nettoyage
        
        Dim saisie As String
        saisie = Trim(Target.Value)
        
        Dim entrees() As String
        Dim entree As String
        Dim parties() As String
        Dim valeurFinaleM As String
        
        entrees = Split(saisie, separateur)
        valeurFinaleM = ""
        
        Dim i As Integer
        For i = 0 To UBound(entrees)
            entree = Trim(entrees(i))
            
            If Not EstFormatValide(entree) Then
                MsgBox "Format invalide : " & entree & Chr(10) & _
                       "Attendu : dd/mm/yyyy: Description", vbExclamation
                Application.Undo
                GoTo Nettoyage
            End If
            
            parties = Split(entree, ": ", 2)
            entree = Format(CDate(parties(0)), "dd/mm/yyyy") & ": " & Trim(parties(1))
            
            If valeurFinaleM = "" Then
                valeurFinaleM = entree
            Else
                valeurFinaleM = valeurFinaleM & separateur & entree
            End If
        Next i
        
        Target.Value = valeurFinaleM
    End If
End If




