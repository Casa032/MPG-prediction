"""
ingestion/excel_parser.py
─────────────────────────
Brique 3 — Lecture du fichier Excel de monitoring.

Rôle : ouvrir le fichier Excel, identifier les sheets quinzaine,
lire chaque sheet et retourner des DataFrames pandas bruts.
La validation des données se fait dans normalizer.py (Brique 4).

Utilisation :
    from ingestion.excel_parser import ExcelParser
    parser = ExcelParser("data/excel/monito.xlsx")
    sheets = parser.parse_all()   # dict { "Q2_2025_S1": DataFrame, ... }
"""

import re
from pathlib import Path

import pandas as pd


class ExcelParser:
    """
    Lit un fichier Excel de monitoring et retourne les données
    de chaque sheet quinzaine sous forme de DataFrames pandas.
    """

    # Colonnes attendues dans chaque sheet quinzaine
    # (doit correspondre à ce qu'on a défini dans le template)
    EXPECTED_COLUMNS = [
        "projet_id",
        "projet_nom",
        "domaine",
        "phase",
        "effectifs",
        "responsable_principal",
        "statut",
        "avancement_pct",
        "livrable_quinzaine",
        "livrable_statut",
        "decisions",
        "actions_a_mener",
        "actions_responsable",
        "actions_echeance",
        "risques",
        "risque_niveau",
        "points_blocage",
        "commentaire_libre",
    ]

    def __init__(self, filepath: str, sheet_pattern: str = r"^Q[1-4]_\d{4}_S[12]$"):
        """
        Parameters
        ----------
        filepath : str
            Chemin vers le fichier Excel (.xlsx)
        sheet_pattern : str
            Expression régulière pour identifier les sheets quinzaine.
            Par défaut : Q1_2025_S1, Q2_2024_S2, etc.
        """
        self.filepath = Path(filepath)
        self.sheet_pattern = sheet_pattern
        self._validate_file()  # on vérifie que le fichier existe dès le départ

    # ─────────────────────────────────────────────────────────────────────────
    # Méthode principale
    # ─────────────────────────────────────────────────────────────────────────

    def parse_all(self) -> dict[str, pd.DataFrame]:
        """
        Lit toutes les sheets quinzaine du fichier Excel.

        Returns
        -------
        dict
            Clés   = nom de la sheet (ex: "Q2_2025_S1")
            Valeurs = DataFrame pandas avec les données brutes de la sheet

        Raises
        ------
        ValueError
            Si aucune sheet quinzaine n'est trouvée dans le fichier.
        """
        # Récupère la liste de toutes les sheets du fichier
        all_sheets = self._get_sheet_names()

        # Filtre : garde seulement les sheets qui matchent le pattern quinzaine
        quinzaine_sheets = [
            s for s in all_sheets if re.match(self.sheet_pattern, s)
        ]

        if not quinzaine_sheets:
            raise ValueError(
                f"Aucune sheet quinzaine trouvée dans '{self.filepath}'.\n"
                f"Pattern attendu : {self.sheet_pattern}\n"
                f"Sheets disponibles : {all_sheets}"
            )

        print(f"  {len(quinzaine_sheets)} sheet(s) quinzaine détectée(s) : {quinzaine_sheets}")

        # Lit chaque sheet et stocke le DataFrame dans un dict
        result = {}
        for sheet_name in sorted(quinzaine_sheets):  # trié chronologiquement
            df = self._read_sheet(sheet_name)
            if df is not None:
                result[sheet_name] = df
                print(f"  ✓ '{sheet_name}' — {len(df)} ligne(s) lue(s)")
            else:
                print(f"  ⚠ '{sheet_name}' — sheet vide, ignorée")

        return result

    def parse_sheet(self, sheet_name: str) -> pd.DataFrame:
        """
        Lit une seule sheet par son nom.

        Parameters
        ----------
        sheet_name : str
            Nom exact de la sheet (ex: "Q2_2025_S1")

        Returns
        -------
        pd.DataFrame
            Données brutes de la sheet.
        """
        return self._read_sheet(sheet_name)

    def parse_meta(self, meta_sheet: str = "META") -> pd.DataFrame:
        """
        Lit la sheet META (référentiel des projets).

        Parameters
        ----------
        meta_sheet : str
            Nom de la sheet META (par défaut "META")

        Returns
        -------
        pd.DataFrame
            Référentiel projets, ou DataFrame vide si absent.
        """
        all_sheets = self._get_sheet_names()
        if meta_sheet not in all_sheets:
            print(f"  ⚠ Sheet '{meta_sheet}' introuvable. Référentiel ignoré.")
            return pd.DataFrame()

        # header=1 car la ligne 0 = titre fusionné, ligne 1 = vrais en-têtes
        df = pd.read_excel(
            self.filepath,
            sheet_name=meta_sheet,
            header=1,        # ligne 2 dans Excel = en-têtes réels
        )
        df = self._clean_dataframe(df)
        print(f"  ✓ META — {len(df)} projet(s) dans le référentiel")
        return df

    def get_quinzaine_sheets(self) -> list[str]:
        """Retourne la liste des sheets quinzaine disponibles, triées."""
        all_sheets = self._get_sheet_names()
        return sorted([s for s in all_sheets if re.match(self.sheet_pattern, s)])

    # ─────────────────────────────────────────────────────────────────────────
    # Méthodes internes (privées, commencent par _)
    # ─────────────────────────────────────────────────────────────────────────

    def _validate_file(self):
        """Vérifie que le fichier existe et est bien un .xlsx."""
        if not self.filepath.exists():
            raise FileNotFoundError(
                f"Fichier introuvable : '{self.filepath}'\n"
                f"Vérifie que le chemin est correct."
            )
        if self.filepath.suffix.lower() not in [".xlsx", ".xlsm"]:
            raise ValueError(
                f"Format non supporté : '{self.filepath.suffix}'. "
                f"Utilise un fichier .xlsx ou .xlsm."
            )

    def _get_sheet_names(self) -> list[str]:
        """Retourne la liste de tous les noms de sheets du fichier."""
        # ExcelFile permet d'accéder aux métadonnées sans charger les données
        with pd.ExcelFile(self.filepath) as xls:
            return xls.sheet_names

    def _read_sheet(self, sheet_name: str) -> pd.DataFrame | None:
        """
        Lit une sheet quinzaine et retourne un DataFrame propre.

        - header=1 : ignore la ligne de titre fusionné (ligne 1)
        - skiprows=[2] : ignore la ligne de légende (ligne 3)
        - Lignes entièrement vides supprimées
        - Noms de colonnes normalisés (minuscules, sans espaces)
        """
        df = pd.read_excel(
            self.filepath,
            sheet_name=sheet_name,
            header=1,        # ligne 2 dans Excel = en-têtes réels
            skiprows=[2],    # ligne 3 = légende, on la saute
        )

        df = self._clean_dataframe(df)

        # Si le DataFrame est vide après nettoyage, on retourne None
        if df.empty:
            return None

        # Ajoute une colonne "quinzaine" pour tracer l'origine des données
        df["quinzaine"] = sheet_name

        # Extrait l'année et le numéro de quinzaine depuis le nom de la sheet
        # Ex: "Q2_2025_S1" → annee=2025, num_quinzaine=3 (Q2 S1 = 3ème quinzaine)
        df["annee"], df["num_quinzaine"] = self._extract_period(sheet_name)

        return df

    def _clean_dataframe(self, df: pd.DataFrame) -> pd.DataFrame:
        """
        Nettoie un DataFrame brut issu de pandas.read_excel :
        - Supprime les lignes entièrement vides
        - Normalise les noms de colonnes
        - Supprime les espaces en trop dans les valeurs texte
        - Remplace les valeurs NaN par None (plus pratique en Python)
        """
        # Supprime les lignes où TOUTES les colonnes sont vides
        df = df.dropna(how="all").reset_index(drop=True)

        # Normalise les noms de colonnes :
        # "Nom du projet " → "nom_du_projet"
        df.columns = (
            df.columns
            .str.strip()           # supprime espaces début/fin
            .str.lower()           # met en minuscules
            .str.replace(" ", "_") # remplace espaces par underscores
            .str.replace(r"[^\w]", "_", regex=True)  # caractères spéciaux → _
            .str.replace(r"_+", "_", regex=True)      # double underscores → un seul
            .str.strip("_")        # supprime underscores en début/fin
        )

        # Supprime les espaces en trop dans les colonnes texte (str)
        for col in df.select_dtypes(include=["object", "string"]).columns:
            df[col] = df[col].astype(str).str.strip()
            # Remplace les "nan" (chaîne) par None
            df[col] = df[col].replace("nan", None)

        return df

    def _extract_period(self, sheet_name: str) -> tuple[int, int]:
        """
        Extrait l'année et le numéro de quinzaine depuis le nom de la sheet.

        Exemples :
            "Q1_2025_S1" → (2025, 1)   1ère quinzaine de l'année
            "Q1_2025_S2" → (2025, 2)   2ème quinzaine
            "Q2_2025_S1" → (2025, 3)   3ème quinzaine
            "Q4_2025_S2" → (2025, 8)   8ème et dernière quinzaine

        Returns
        -------
        tuple (annee: int, num_quinzaine: int)
        """
        # Pattern : Q{trimestre}_{annee}_S{semaine_dans_trimestre}
        match = re.match(r"Q(\d)_(\d{4})_S(\d)", sheet_name)
        if not match:
            return (0, 0)  # fallback si le pattern ne matche pas

        trimestre = int(match.group(1))   # 1, 2, 3 ou 4
        annee     = int(match.group(2))   # ex: 2025
        semaine   = int(match.group(3))   # 1 ou 2

        # Chaque trimestre a 2 quinzaines → num global = (trimestre-1)*2 + semaine
        num_quinzaine = (trimestre - 1) * 2 + semaine

        return annee, num_quinzaine


