@app.callback(
    [Output("cni2", "children"), Output("cni3", "children")],
    [Input("cni_client", "value")],
    State('cni_periodePar', 'start_date'),
    State('cni_periodePar', 'end_date'),
)
def cnicateidentite2(client, debut, fin):

    df_cni = df[
        (df['datefinal'] >= debut) &
        (df['datefinal'] <= fin) &
        (df['idt_grp_cli'] == client)
    ]

    df_cni = df_cni[
        ['idt_grp_cli','canal','macro','interaction',
         'dateheure','tr_age_120220300',
         'region_120220300','personae_120220300']
    ]

    df_cni.sort_values(by=['dateheure'], ascending=True, inplace=True)

    card_icon = {
        "color": "white",
        "textAlign": "center",
        "fontSize": 30,
        "margin": "auto",
    }

    # -------------------------
    # PROFIL CLIENT
    # -------------------------

    profil = []

    tmp = df_cni[
        ['idt_grp_cli','tr_age_120220300',
         'region_120220300','personae_120220300']
    ]

    idt_grp_cli = tmp['idt_grp_cli'].tolist()
    tr_age = tmp['tr_age_120220300'].tolist()
    marche = tmp['region_120220300'].tolist()
    score_personae = tmp['personae_120220300'].tolist()

    profil_card = dbc.CardGroup([

        dbc.Card(
            html.Div(className="fas fa-users", style=card_icon),
            className="bg-info",
            style={"maxWidth": 75},
        ),

        dbc.Card(
            dbc.CardBody([

                html.P("identifiant : " + str(idt_grp_cli[0]), className="card-text"),
                html.P("age : " + str(tr_age[0]), className="card-text"),
                html.P("region : " + str(marche[0]), className="card-text"),
                html.P("score personae : " + str(score_personae[0]), className="card-text"),

            ])
        ),

    ], className="mt-4 shadow")

    profil.append(profil_card)

    # -------------------------
    # PARCOURS PAR CANAL
    # -------------------------

    icons = {
        "WEB": "fas fa-globe",
        "COURRIER": "fas fa-envelope",
        "SYSTEME": "fas fa-industry",
        "EMAIL": "fas fa-inbox",
        "APPEL ENTRANT": "fas fa-phone",
        "APPEL SORTANT": "fas fa-phone",
    }

    accordion_items = []

    for canal, df_canal in df_cni.groupby("canal"):

        cards = []

        for i in range(df_canal.shape[0]):

            row = df_canal.iloc[i]

            date = row["dateheure"]
            interaction = row["interaction"]

            icon = icons.get(canal, "fas fa-users")

            card = dbc.CardGroup([

                dbc.Card(
                    html.Div(className=icon, style=card_icon),
                    className="bg-info",
                    style={"maxWidth": 75},
                ),

                dbc.Card(
                    dbc.CardBody([
                        html.P(
                            str(date) + " : " + canal + " - " + interaction,
                            className="card-text",
                        )
                    ])
                ),

            ], className="mt-2 shadow")

            cards.append(card)

        accordion_items.append(
            dbc.AccordionItem(
                children=cards,
                title=canal
            )
        )

    parcours = dbc.Accordion(
        accordion_items,
        start_collapsed=True,
        always_open=True
    )

    return parcours, profil
