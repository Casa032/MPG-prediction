@app.callback(
    Output('ca_filtre_ajout', 'children'),
    Input('ca_filtre_ajouter', 'n_clicks'),
    Input({'type': 'ca_filtre_delete','index': ALL}, 'n_clicks'),
    State('ca_filtre_ajout', 'children')
)
def gestion_filtre(n_add, n_delete, children):

    ctx = dash.callback_context

    if not ctx.triggered:
        return children

    trigger = ctx.triggered[0]['prop_id']

    # ---------------------
    # AJOUT FILTRE
    # ---------------------

    if "ca_filtre_ajouter" in trigger:

        index = len(children)

        tmp = dbc.Row([

            dbc.Col([
                dcc.Dropdown(
                    id={'type': 'ca_filtre_op','index': index},
                    options=[{'label': 'ET', 'value': 'ET'},
                             {'label': 'OU', 'value': 'OU'}],
                    value="ET"
                )
            ], width=2),

            dbc.Col([
                dcc.Dropdown(
                    id={'type': 'ca_filtre_var','index': index},
                    options=[{'label':name, 'value':name} for name in names],
                    value=list(fnameDict.keys())[0]
                )
            ], width=3),

            dbc.Col([
                dcc.Dropdown(
                    id={'type': 'ca_filtre_mod','index': index},
                    multi=True
                )
            ], width=5),

            dbc.Col([
                dbc.Button(
                    "X",
                    id={'type':'ca_filtre_delete','index':index},
                    color="danger",
                    size="sm"
                )
            ], width=1)

        ])

        children.append(tmp)

    # ---------------------
    # SUPPRESSION
    # ---------------------

    elif "ca_filtre_delete" in trigger:

        index = int(trigger.split('"index":')[1].split('}')[0])

        children = [
            child for i, child in enumerate(children)
            if i != index
        ]

    return children


