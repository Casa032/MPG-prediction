"""
normalizer.py
=============
Valide et nettoie les données brutes lues depuis le fichier Excel.

Rôle dans le pipeline :
    excel_parser.py  →  normalizer.py  →  storage.py

Ce module fait 4 choses :
    1. Vérifie que toutes les colonnes obligatoires sont présentes
    2. Contrôle que les valeurs des colonnes à liste fermée sont valides
    3. Nettoie les données (espaces, casse, dates)
    4. Retourne un rapport d'erreurs si des problèmes sont trouvés
"""

import pandas as pd
from datetime import datetime
from dataclasses import dataclass, field


# ── Schéma de référence ────────────────────────────────────────────────────────

# Colonnes obligatoires : le normalizer rejettera toute ligne où l'une d'elles est vide
COLONNES_OBLIGATOIRES = [
    "projet_id",
    "projet_nom",
    "domaine",
    "phase",
    "effectifs",
    "responsable_principal",
    "statut",
    "avancement_pct",
    "livrable_quinzaine",
    "livrable_statut",
]

# Colonnes optionnelles : autorisées vides, mais nettoyées si présentes
COLONNES_OPTIONNELLES = [
    "decisions",
    "actions_a_mener",
    "actions_responsable",
    "actions_echeance",
    "risques",
    "risque_niveau",
    "points_blocage",
    "commentaire_libre",
]

# Toutes les colonnes attendues dans l'ordre
TOUTES_LES_COLONNES = COLONNES_OBLIGATOIRES + COLONNES_OPTIONNELLES

# Valeurs autorisées pour les colonnes à liste fermée
VALEURS_AUTORISEES = {
    "statut":          {"ON_TRACK", "AT_RISK", "LATE", "DONE", "ON_HOLD"},
    "livrable_statut": {"LIVRE", "EN_COURS", "NON_LIVRE", "REPORTE"},
    "risque_niveau":   {"FAIBLE", "MOYEN", "ELEVE", "CRITIQUE"},
    "domaine":         {"DATA", "SI", "SECURITE", "METIER", "FINANCE", "RH", "AUTRE"},
    "phase":           {"Initiation", "Cadrage", "Réalisation", "Recette", "Clôture"},
}


# ── Structure de résultat ──────────────────────────────────────────────────────

@dataclass
class ResultatNormalisation:
    """
    Objet retourné par la fonction principale `normaliser()`.
    
    Attributs :
        succes      : True si les données sont valides et utilisables
        df_propre   : DataFrame nettoyé (None si succes=False)
        erreurs     : liste des problèmes bloquants (colonnes manquantes, valeurs invalides)
        avertissements : problèmes non bloquants (données manquantes dans colonnes optionnelles)
        stats       : dictionnaire avec des chiffres clés sur les données
    """
    succes: bool
    df_propre: pd.DataFrame | None
    erreurs: list = field(default_factory=list)
    avertissements: list = field(default_factory=list)
    stats: dict = field(default_factory=dict)

    def afficher_rapport(self):
        """Affiche un résumé lisible dans le terminal."""
        print("\n" + "=" * 55)
        print("  RAPPORT DE NORMALISATION")
        print("=" * 55)
        
        statut = "SUCCÈS" if self.succes else "ÉCHEC"
        print(f"  Statut    : {statut}")
        
        if self.stats:
            print(f"  Lignes    : {self.stats.get('lignes_valides', 0)} valides / "
                  f"{self.stats.get('lignes_total', 0)} total")
            print(f"  Projets   : {self.stats.get('nb_projets_uniques', 0)} uniques")
        
        if self.erreurs:
            print(f"\n  ERREURS ({len(self.erreurs)}) :")
            for e in self.erreurs:
                print(f"    ✗ {e}")
        
        if self.avertissements:
            print(f"\n  Avertissements ({len(self.avertissements)}) :")
            for a in self.avertissements:
                print(f"    ~ {a}")
        
        print("=" * 55 + "\n")


# ── Fonctions de nettoyage ─────────────────────────────────────────────────────

def _nettoyer_texte(valeur) -> str:
    """
    Nettoie une valeur texte :
    - Convertit en string
    - Retire les espaces inutiles en début/fin
    - Remplace les valeurs vides/NaN par une chaîne vide
    """
    if pd.isna(valeur) or valeur is None:
        return ""
    return str(valeur).strip()


def _nettoyer_entier(valeur, nom_colonne: str, erreurs: list) -> int | None:
    """
    Convertit une valeur en entier entre 0 et 100.
    Ajoute une erreur si la conversion échoue.
    """
    if pd.isna(valeur) or valeur == "":
        return None
    try:
        n = int(float(str(valeur).strip()))
        if not (0 <= n <= 100):
            erreurs.append(
                f"'{nom_colonne}' doit être entre 0 et 100 — valeur reçue : {n}"
            )
            return None
        return n
    except (ValueError, TypeError):
        erreurs.append(
            f"'{nom_colonne}' doit être un nombre entier — valeur reçue : '{valeur}'"
        )
        return None


def _nettoyer_date(valeur) -> str:
    """
    Essaie de parser une date dans plusieurs formats courants.
    Retourne la date au format ISO (YYYY-MM-DD) ou une chaîne vide si échec.
    """
    if pd.isna(valeur) or str(valeur).strip() == "":
        return ""
    
    valeur_str = str(valeur).strip()
    
    # Si pandas a déjà parsé la date (type Timestamp)
    if isinstance(valeur, pd.Timestamp):
        return valeur.strftime("%Y-%m-%d")
    
    # Formats courants en France et en ISO
    formats = ["%d/%m/%Y", "%Y-%m-%d", "%d-%m-%Y", "%d.%m.%Y"]
    for fmt in formats:
        try:
            return datetime.strptime(valeur_str, fmt).strftime("%Y-%m-%d")
        except ValueError:
            continue
    
    # Si aucun format ne marche, on garde la valeur brute avec un avertissement
    return valeur_str


def _valider_valeur_liste(valeur: str, colonne: str, valeurs_ok: set,
                           avertissements: list) -> str:
    """
    Vérifie qu'une valeur appartient à l'ensemble des valeurs autorisées.
    - Si oui : retourne la valeur telle quelle
    - Si non : ajoute un avertissement et retourne la valeur quand même
               (non bloquant — on préfère garder la donnée)
    """
    if valeur == "":
        return valeur
    
    if valeur not in valeurs_ok:
        valeurs_affichees = ", ".join(sorted(valeurs_ok))
        avertissements.append(
            f"Valeur inattendue dans '{colonne}' : '{valeur}' "
            f"(valeurs attendues : {valeurs_affichees})"
        )
    
    return valeur


# ── Fonction principale ────────────────────────────────────────────────────────

def normaliser(df_brut: pd.DataFrame, nom_quinzaine: str = "") -> ResultatNormalisation:
    """
    Normalise un DataFrame brut issu d'une sheet Excel.

    Paramètres :
        df_brut       : DataFrame pandas brut (1 ligne = 1 projet)
        nom_quinzaine : nom de la sheet d'origine (ex: "Q1_2025_S1")
                        utilisé dans les messages d'erreur

    Retourne :
        ResultatNormalisation avec le DataFrame propre ou les erreurs trouvées
    """
    erreurs = []
    avertissements = []
    prefix = f"[{nom_quinzaine}] " if nom_quinzaine else ""

    # ── Étape 1 : vérifier les colonnes présentes ──────────────────────────────
    colonnes_manquantes = [
        col for col in COLONNES_OBLIGATOIRES
        if col not in df_brut.columns
    ]
    if colonnes_manquantes:
        erreurs.append(
            f"{prefix}Colonnes obligatoires manquantes : {', '.join(colonnes_manquantes)}"
        )
        # Erreur bloquante : impossible de continuer sans ces colonnes
        return ResultatNormalisation(succes=False, df_propre=None,
                                      erreurs=erreurs, avertissements=avertissements)

    # Signaler les colonnes optionnelles absentes (non bloquant)
    for col in COLONNES_OPTIONNELLES:
        if col not in df_brut.columns:
            avertissements.append(
                f"{prefix}Colonne optionnelle absente (sera créée vide) : '{col}'"
            )
            df_brut[col] = ""

    # ── Étape 2 : supprimer les lignes entièrement vides ──────────────────────
    df = df_brut.copy()
    nb_avant = len(df)
    df = df.dropna(how="all")         # lignes 100% vides
    df = df.reset_index(drop=True)
    nb_vides = nb_avant - len(df)
    if nb_vides > 0:
        avertissements.append(f"{prefix}{nb_vides} ligne(s) entièrement vide(s) ignorée(s)")

    # ── Étape 3 : nettoyer et valider colonne par colonne ─────────────────────
    lignes_invalides = []  # indices des lignes avec erreurs bloquantes

    for idx in df.index:
        erreurs_ligne = []

        # --- Colonnes texte simples ---
        for col in ["projet_id", "projet_nom", "effectifs",
                    "responsable_principal", "livrable_quinzaine",
                    "decisions", "actions_a_mener", "actions_responsable",
                    "risques", "points_blocage", "commentaire_libre"]:
            if col in df.columns:
                df.at[idx, col] = _nettoyer_texte(df.at[idx, col])

        # --- Colonnes à valeurs contrôlées (mise en majuscules automatique) ---
        for col in ["statut", "livrable_statut", "risque_niveau", "domaine"]:
            if col in df.columns:
                valeur = _nettoyer_texte(df.at[idx, col]).upper()
                df.at[idx, col] = _valider_valeur_liste(
                    valeur, col, VALEURS_AUTORISEES[col], avertissements
                )

        # --- Phase : casse mixte (ex: "Réalisation") ---
        if "phase" in df.columns:
            valeur = _nettoyer_texte(df.at[idx, "phase"])
            # On cherche la correspondance insensible à la casse
            correspondance = next(
                (v for v in VALEURS_AUTORISEES["phase"]
                 if v.lower() == valeur.lower()),
                valeur  # garde la valeur originale si pas trouvée
            )
            df.at[idx, "phase"] = _valider_valeur_liste(
                correspondance, "phase", VALEURS_AUTORISEES["phase"], avertissements
            )

        # --- Avancement en pourcentage ---
        if "avancement_pct" in df.columns:
            pct = _nettoyer_entier(df.at[idx, "avancement_pct"],
                                   "avancement_pct", erreurs_ligne)
            df.at[idx, "avancement_pct"] = pct

        # --- Date d'échéance ---
        if "actions_echeance" in df.columns:
            df.at[idx, "actions_echeance"] = _nettoyer_date(
                df.at[idx, "actions_echeance"]
            )

        # --- Vérification colonnes obligatoires non vides ---
        for col in COLONNES_OBLIGATOIRES:
            valeur = df.at[idx, col]
            if valeur is None or str(valeur).strip() == "" or pd.isna(valeur) if not isinstance(valeur, str) else valeur.strip() == "":
                erreurs_ligne.append(
                    f"Colonne obligatoire vide : '{col}' (ligne {idx + 2})"
                )

        if erreurs_ligne:
            # On signale mais on ne bloque pas — la ligne est marquée invalide
            for e in erreurs_ligne:
                avertissements.append(f"{prefix}{e}")
            lignes_invalides.append(idx)

    # ── Étape 4 : retirer les lignes invalides, calculer les stats ────────────
    df_propre = df.drop(index=lignes_invalides).reset_index(drop=True)

    # Ajouter la colonne quinzaine pour la traçabilité
    df_propre["quinzaine"] = nom_quinzaine

    # Réordonner les colonnes : quinzaine en premier, puis le reste dans l'ordre défini
    colonnes_finales = ["quinzaine"] + [
        col for col in TOUTES_LES_COLONNES if col in df_propre.columns
    ]
    df_propre = df_propre[colonnes_finales]

    stats = {
        "lignes_total":        len(df),
        "lignes_valides":      len(df_propre),
        "lignes_rejetees":     len(lignes_invalides),
        "nb_projets_uniques":  df_propre["projet_id"].nunique(),
        "quinzaine":           nom_quinzaine,
    }

    succes = len(erreurs) == 0  # bloquant seulement si erreurs de structure

    return ResultatNormalisation(
        succes=succes,
        df_propre=df_propre if succes else None,
        erreurs=erreurs,
        avertissements=avertissements,
        stats=stats,
    )


