    print(f"\n{'='*55}")
    print(f"  Test ExcelParser")
    print(f"  Fichier : {filepath}")
    print(f"{'='*55}\n")

    parser = ExcelParser(filepath)

    print("── Sheets disponibles ──────────────────────────────────")
    print(f"  Toutes       : {parser._get_sheet_names()}")
    print(f"  Quinzaines   : {parser.get_quinzaine_sheets()}")

    print("\n── Lecture META ────────────────────────────────────────")
    meta = parser.parse_meta()
