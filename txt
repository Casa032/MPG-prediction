<script>
    const dataPays    = {json.dumps(data_pays)};
    const dataDetails = {json.dumps(data_details)};
    const dataIA      = {json.dumps(data_ia)};

    const API_KEY     = "{API_KEY}";
    const BASE_URL    = "{BASE_URL}";
    const MODEL       = "{PARAMS['model']}";
    const MAX_TOKENS  = {PARAMS['max_tokens']};
    const TEMPERATURE = {PARAMS['temperature']};

    let selectedFilters         = null;
    let filteredDataForAnalysis = [];

    // ── Navigation ──────────────────────────────────────────────────────────
    function showPage(pageId, btn) {{
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
        document.getElementById(pageId).classList.add('active');
        btn.classList.add('active');
        if (pageId === 'page2') initPage2();
    }}

    // ── Carte Plotly ─────────────────────────────────────────────────────────
    function createMap() {{
        const mapData = [{{
            type         : 'choropleth',
            locationmode : 'ISO-3',
            locations    : dataPays.code,
            z            : dataPays.valeur,
            text         : dataPays.pays,
            colorscale   : 'Reds',
            hovertemplate: '<b>%{{text}}</b><br>Projets: %{{z:,.0f}}<extra></extra>',
            colorbar     : {{ title: 'Projets' }}
        }}];

        const layout = {{
            title : '<b>Projets Cofidis par pays</b>',
            geo   : {{
                scope        : 'europe',
                projection   : {{ type: 'natural earth' }},
                showland     : true,
                landcolor    : 'rgb(243,243,243)',
                coastlinecolor: 'rgb(204,204,204)',
                showlakes    : true,
                lakecolor    : 'rgb(230,245,255)',
                showcountries: true,
                countrycolor : 'rgb(204,204,204)'
            }},
            margin: {{l:0, r:0, t:40, b:0}},
            height: 500
        }};

        Plotly.newPlot('map', mapData, layout, {{displayModeBar: false}});

        document.getElementById('map').on('plotly_click', function(evtData) {{
            const point = evtData.points[0];
            const index = dataPays.code.indexOf(point.location);
            if (index !== -1) showCountryData(dataPays.pays[index]);
        }});
    }}

    // ── Détail pays ──────────────────────────────────────────────────────────
    function showCountryData(pays) {{
        const filtered = dataDetails.filter(d => d.Entité === pays);
        if (!filtered.length) return;

        let html = `
            <h3>📋 Projets : <span style="color:#3498db">${{pays}}</span></h3>
            <div class="stats-box" style="margin:15px 0">
                <div class="stat-item">
                    <div class="stat-value" style="color:#27ae60">0</div>
                    <div class="stat-label">Nouveaux projets</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" style="color:#3498db">${{filtered.length}}</div>
                    <div class="stat-label">Projets</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" style="color:#e74c3c">${{dataIA[pays] ?? 0}}</div>
                    <div class="stat-label">Cas d'usage IA</div>
                </div>
            </div>
            <div class="table-container">
                <table>
                    <thead><tr>
                        <th>Entité</th><th>Domaine</th><th>Sujet</th>
                        <th>Contact entité</th><th>Cas d'usage IA</th><th>État</th>
                    </tr></thead>
                    <tbody>
        `;

        filtered.forEach(d => {{
            html += `<tr>
                <td>${{d.Entité}}</td><td>${{d.Domaine}}</td><td>${{d.Sujet}}</td>
                <td>${{d.ContactEntite}}</td><td>${{d.UsageIA}}</td><td>${{d.ETAT}}</td>
            </tr>`;
        }});

        html += `</tbody></table></div>`;
        document.getElementById('country-table-container').innerHTML = html;
    }}

    // ── Init page 2 ──────────────────────────────────────────────────────────
    function initPage2() {{
        const fill = (id, values) => {{
            document.getElementById(id).innerHTML =
                values.map(v => `<option value="${{v}}" ${{v === 'Tous' ? 'selected' : ''}}>${{v}}</option>`).join('');
        }};

        fill('filter-entite',    ['Tous', ...new Set(dataDetails.map(d => d.Entité))].sort());
        fill('filter-domaine',   ['Tous', ...new Set(dataDetails.map(d => d.Domaine))].sort());
        fill('filter-usageIA',   ['Tous', ...new Set(dataDetails.map(d => d.UsageIA))].sort());
        fill('filter-etat',      ['Tous', ...new Set(dataDetails.map(d => d.ETAT))].sort());
        fill('filter-evolution', ['Tous', ...new Set(dataDetails.map(d => d.Évolution_significative))].sort());

        applyFilters();
    }}

    // ── Filtres ───────────────────────────────────────────────────────────────
    function applyFilters() {{
        const fe  = document.getElementById('filter-entite').value;
        const fd  = document.getElementById('filter-domaine').value;
        const fu  = document.getElementById('filter-usageIA').value;
        const fst = document.getElementById('filter-etat').value;
        const fev = document.getElementById('filter-evolution').value;
        const kw  = document.getElementById('keyword-search').value.toLowerCase();

        const filtered = dataDetails.filter(d => {{
            if (fe  !== 'Tous' && d.Entité                  !== fe)  return false;
            if (fd  !== 'Tous' && d.Domaine                 !== fd)  return false;
            if (fu  !== 'Tous' && d.UsageIA                 !== fu)  return false;
            if (fst !== 'Tous' && d.ETAT                    !== fst) return false;
            if (fev !== 'Tous' && d.Évolution_significative  !== fev) return false;
            if (kw && !Object.values(d).some(v => String(v).toLowerCase().includes(kw))) return false;
            return true;
        }});

        document.getElementById('stat-count').textContent = filtered.length;

        document.getElementById('table-body').innerHTML = filtered.map(d => `
            <tr>
                <td>${{d.Entité}}</td>
                <td>${{d.Domaine}}</td>
                <td>${{d.Sujet}}</td>
                <td>${{d.Descriptif}}</td>
                <td>${{d.ContactEntite}}</td>
                <td>${{d.UsageIA}}</td>
                <td>${{d.majRDMI}}</td>
                <td>${{d.ETAT}}</td>
                <td>${{d.Commentaires}}</td>
                <td>${{d.Date_de_la_dernière_maj}}</td>
                <td>${{d.Évolution_significative}}</td>
                <td>${{d.Communautaire}}</td>
                <td>${{d.Éntités_participantes_si_communautaire}}</td>
                <td>${{d.Modalités_de_l_organisation}}</td>
                <td>${{d.Webinar}}</td>
            </tr>
        `).join('');

        filteredDataForAnalysis = filtered;

        const hasFilter = fe !== 'Tous' || fd !== 'Tous' || fu !== 'Tous' ||
                          fst !== 'Tous' || fev !== 'Tous' || kw !== '';
        document.getElementById('validate-btn-container').style.display = hasFilter ? 'block' : 'none';
    }}

    // ── Valider → page 3 ─────────────────────────────────────────────────────
    function validateSelection() {{
        selectedFilters = {{
            entite   : document.getElementById('filter-entite').value,
            domaine  : document.getElementById('filter-domaine').value,
            usageIA  : document.getElementById('filter-usageIA').value,
            etat     : document.getElementById('filter-etat').value,
            evolution: document.getElementById('filter-evolution').value,
            keyword  : document.getElementById('keyword-search').value,
            nbProjets: filteredDataForAnalysis.length
        }};

        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('page3').classList.add('active');

        document.getElementById('nb-projets-label').textContent     = filteredDataForAnalysis.length;
        document.getElementById('user-question').value               = '';
        document.getElementById('analyse-ia').style.display          = 'none';
        document.getElementById('analyse-ia').textContent            = '';
        document.getElementById('analyse-loader').style.display      = 'flex';
        document.getElementById('analyse-titre').textContent         = '🤖 Analyse automatique';

        displayFiltersSummary();
        launchLLMAnalysis();
    }}

    // ── Résumé filtres ────────────────────────────────────────────────────────
    function displayFiltersSummary() {{
        const f = selectedFilters;
        const parts = [];
        if (f.entite    !== 'Tous') parts.push(`Entité : <b>${{f.entite}}</b>`);
        if (f.domaine   !== 'Tous') parts.push(`Domaine : <b>${{f.domaine}}</b>`);
        if (f.usageIA   !== 'Tous') parts.push(`Cas d'usage IA : <b>${{f.usageIA}}</b>`);
        if (f.etat      !== 'Tous') parts.push(`État : <b>${{f.etat}}</b>`);
        if (f.evolution !== 'Tous') parts.push(`Évolution : <b>${{f.evolution}}</b>`);
        if (f.keyword)              parts.push(`Mot-clé : <b>"${{f.keyword}}"</b>`);

        document.getElementById('filters-summary').innerHTML = parts.length
            ? `🎯 <b>Filtres appliqués :</b> ${{parts.join(' &nbsp;|&nbsp; ')}} — <b>${{f.nbProjets}} projet(s)</b>`
            : `🎯 Analyse globale — <b>${{f.nbProjets}} projet(s)</b>`;
    }}

    // ── Appel LLM générique ───────────────────────────────────────────────────
    async function callLLM(prompt) {{
        const response = await fetch(BASE_URL + "chat/completions", {{
            method : "POST",
            headers: {{
                "Content-Type" : "application/json",
                "Authorization": `Bearer ${{API_KEY}}`
            }},
            body: JSON.stringify({{
                model      : MODEL,
                max_tokens : MAX_TOKENS,
                temperature: TEMPERATURE,
                messages   : [{{ role: "user", content: prompt }}]
            }})
        }});
        const data = await response.json();
        return data.choices[0].message.content;
    }}

    // ── Analyse automatique ───────────────────────────────────────────────────
    async function launchLLMAnalysis() {{
        const prompt = `Tu es un assistant spécialisé UNIQUEMENT dans l'analyse du portefeuille de projets Data & IA de Cofidis Group.

RÈGLES STRICTES :
- Tu ne réponds QU'aux questions portant sur les données de projets fournies ci-dessous.
- Si la question ne concerne pas ces projets (ex: météo, actualités, coding, sujets généraux), tu réponds UNIQUEMENT : "❌ Je suis limité à l'analyse des projets sélectionnés. Posez une question sur les données filtrées (entités, domaines, états, cas d'usage IA, tendances, risques...)."
- Tu ne fais pas de suppositions sur des données absentes.
- Tu bases ta réponse UNIQUEMENT sur les données fournies.

CONTEXTE DES DONNÉES :
- Nombre de projets sélectionnés : ${{filteredDataForAnalysis.length}}
- Filtres appliqués :
  · Entité : ${{selectedFilters.entite}}
  · Domaine : ${{selectedFilters.domaine}}
  · Cas d'usage IA : ${{selectedFilters.usageIA}}
  · État : ${{selectedFilters.etat}}
  · Évolution : ${{selectedFilters.evolution}}

DONNÉES DES PROJETS :
${{JSON.stringify(filteredDataForAnalysis, null, 2)}}

QUESTION DE L'UTILISATEUR : ${{question}}

Réponds en français, de façon claire et structurée, en te basant uniquement sur les données ci-dessus.`;

        try {{
            const texte = await callLLM(prompt);
            document.getElementById('analyse-loader').style.display = 'none';
            document.getElementById('analyse-ia').style.display     = 'block';
            document.getElementById('analyse-ia').textContent       = texte;
        }} catch(err) {{
            document.getElementById('analyse-loader').style.display = 'none';
            document.getElementById('analyse-ia').style.display     = 'block';
            document.getElementById('analyse-ia').textContent       = '❌ Erreur API : ' + err.message;
        }}
    }}

    // ── Question personnalisée ────────────────────────────────────────────────
    async function askCustomQuestion() {{
        const question = document.getElementById('user-question').value.trim();

        if (!question) {{
            const ta = document.getElementById('user-question');
            ta.style.borderColor = '#e74c3c';
            setTimeout(() => ta.style.borderColor = '#bdc3c7', 2000);
            return;
        }}

        const btn = document.getElementById('ask-btn');
        btn.disabled    = true;
        btn.textContent = '⏳ En cours...';

        document.getElementById('analyse-ia').style.display          = 'none';
        document.getElementById('analyse-ia').textContent            = '';
        document.getElementById('analyse-loader').style.display      = 'flex';
        document.getElementById('analyse-titre').textContent         = `💬 Réponse à : "${{question}}"`;

        const prompt = `Tu es un expert en analyse de portefeuille de projets IA.
L'utilisateur a sélectionné ${{filteredDataForAnalysis.length}} projet(s) avec les filtres suivants :
- Entité : ${{selectedFilters.entite}}
- Domaine : ${{selectedFilters.domaine}}
- Cas d'usage IA : ${{selectedFilters.usageIA}}
- État : ${{selectedFilters.etat}}

Voici les données des projets sélectionnés :
${{JSON.stringify(filteredDataForAnalysis, null, 2)}}

Question de l'utilisateur : ${{question}}

Réponds en français, de façon claire et structurée.`;

        try {{
            const texte = await callLLM(prompt);
            document.getElementById('analyse-loader').style.display = 'none';
            document.getElementById('analyse-ia').style.display     = 'block';
            document.getElementById('analyse-ia').textContent       = texte;
        }} catch(err) {{
            document.getElementById('analyse-loader').style.display = 'none';
            document.getElementById('analyse-ia').style.display     = 'block';
            document.getElementById('analyse-ia').textContent       = '❌ Erreur API : ' + err.message;
        }} finally {{
            btn.disabled    = false;
            btn.textContent = '➤ Envoyer';
        }}
    }}

    // ── Init ──────────────────────────────────────────────────────────────────
    createMap();
</script>
</body>
</html>"""

