# ═══════════════════════════════════════════════════════════════════════════════
# config.yaml — Configuration centrale de Project Intelligence
# Modifie ce fichier selon ton environnement. Ne jamais mettre de mots de passe
# ici : utilise le fichier .env pour les secrets (voir section llm ci-dessous)
# ═══════════════════════════════════════════════════════════════════════════════

# ── Chemins ───────────────────────────────────────────────────────────────────
paths:
  # Dossier où tu déposes les fichiers Excel de monitoring
  excel_input:    "data/excel/"

  # Base DuckDB (fichier local, créé automatiquement au premier lancement)
  duckdb:         "data/storage/monito.duckdb"

  # Dossier de la base vectorielle ChromaDB
  chroma:         "data/storage/chroma/"

  # Fichiers Parquet de sauvegarde (backup des données structurées)
  parquet:        "data/storage/parquet/"

  # Templates HTML pour la génération PDF
  templates:      "templates/"

  # PDF générés
  pdf_output:     "data/outputs/pdf/"

  # Fichiers de logs
  logs:           "logs/app.log"


# ── Schéma Excel attendu ──────────────────────────────────────────────────────
excel:
  # Convention de nommage des sheets quinzaine (regex)
  # Exemples valides : Q1_2025_S1, Q2_2024_S2
  sheet_pattern:  "^Q[1-4]_\\d{4}_S[12]$"

  # Sheet du référentiel projets
  meta_sheet:     "META"

  # Colonnes obligatoires — le parser rejettera une ligne si l'une manque
  required_columns:
    - projet_id
    - projet_nom
    - domaine
    - phase
    - effectifs
    - responsable_principal
    - statut
    - avancement_pct
    - livrable_quinzaine
    - livrable_statut

  # Valeurs autorisées par colonne (validation à l'ingestion)
  allowed_values:
    statut:
      - ON_TRACK
      - AT_RISK
      - LATE
      - DONE
      - ON_HOLD
    livrable_statut:
      - LIVRE
      - EN_COURS
      - NON_LIVRE
      - REPORTE
    risque_niveau:
      - FAIBLE
      - MOYEN
      - ELEVE
      - CRITIQUE
    phase:
      - Initiation
      - Cadrage
      - Réalisation
      - Recette
      - Clôture


# ── LLM — endpoint interne ───────────────────────────────────────────────────
# La clé API doit être dans le fichier .env : LLM_API_KEY=xxx
# L'URL de base pointe vers votre serveur interne (compatible OpenAI)
llm:
  base_url:       "https://votre-llm-interne.entreprise.fr/v1"
  model:          "votre-modele-interne"   # ex: gpt-4, mistral-7b, etc.
  max_tokens:     2048
  temperature:    0.1    # faible = réponses plus factuelles, moins créatives
  timeout_sec:    30


# ── RAG (Retrieval-Augmented Generation) ─────────────────────────────────────
rag:
  # Modèle d'embedding pour transformer le texte en vecteurs
  # Si votre LLM interne expose un endpoint embeddings, mettez son URL dans .env
  # Sinon on utilise un modèle local léger (all-MiniLM-L6-v2)
  embedding_model:  "all-MiniLM-L6-v2"    # modèle local, pas besoin d'API

  # Nombre de passages similaires retournés lors d'une recherche
  top_k:            5

  # Nom de la collection dans ChromaDB
  collection_name:  "monito_projets"


# ── Interface Dash ────────────────────────────────────────────────────────────
app:
  title:          "Project Intelligence"
  host:           "0.0.0.0"    # 0.0.0.0 = accessible depuis le réseau local
  port:           8050
  debug:          true          # passer à false en production


# ── PDF ───────────────────────────────────────────────────────────────────────
pdf:
  # Template HTML de base pour les rapports
  default_template: "rapport_quinzaine.html"
  # Marges en mm
  margin_top:     15
  margin_bottom:  15
  margin_left:    20
  margin_right:   20
