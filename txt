        cols_apercu = ["projet_id", "projet_nom", "statut", "avancement_pct", "quinzaine"]
        cols_ok = [c for c in cols_apercu if c in df.columns]
        print(df[cols_ok].to_string(index=False))

    print(f"\n{'='*55}")
    print("  ExcelParser OK")
    print(f"{'='*55}\n")
