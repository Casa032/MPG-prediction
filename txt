                  ca_topfiltre,
                  ca_filtre_var,ca_filtre_mod,ca_filtre_op,
                  ca_topmode):

    ctx = dash.callback_context

    global ca_duree_fin
    global ca_date_fin

    # -----------------------
    # CORRECTION DATE
    # -----------------------

    start_date = pd.to_datetime(start_date)
    end_date = pd.to_datetime(end_date)

    parametre = ctx.states

    nb_etape = (ca_ajouter_etape or 0) + 1

    df_aeulieu=[]
    df_aeulieu2=[]
    df_nbcritere=[]
    df_duree=[]

    for i in range(nb_etape):

        df_aeulieu.append(parametre[f'{{"index":{i},"type":"ca_eu_lieu"}}.value'])

        if i==0:
            df_duree.append(100)
        else:
            df_duree.append(parametre[f'{{"index":{i},"type":"ca_etape_duree"}}.value'])

        clic = parametre[f'{{"index":{i},"type":"ca_ajouter_etape_critere"}}.n_clicks']

        if clic is None:
            df_nbcritere.append(1)
        else:
            df_nbcritere.append(clic+1)

        if i==0:
            df_aeulieu2=["OUI"]
        else:
            df_aeulieu2.append(parametre[f'{{"index":{i},"type":"ca_eu_lieu2"}}.value'])

    # -----------------------
    # FILTRES
    # -----------------------

    global nb_critere_filtre
    nb_filtre=nb_critere_filtre

    top_filtre = ca_topfiltre

    filtre_var=[]
    filtre_mod=[]
    filtre_op=[' ']

    if top_filtre=='Oui':

        for i in range(nb_filtre):

            if i>0:
                if parametre[f'{{"index":{i},"type":"ca_filtre_op"}}.value']=='ET':
                    filtre_op.append('&')
                else:
                    filtre_op.append('|')

            filtre_var.append(parametre[f'{{"index":{i},"type":"ca_filtre_var"}}.value'])
            filtre_mod.append(parametre[f'{{"index":{i},"type":"ca_filtre_mod"}}.value'])

    if top_filtre=='Oui':

        requete=""

        for i in range(nb_filtre):

            tmp_rqt=""

            test=filtre_mod[i]

            for j in range(len(test)):

                if j==0:
                    tmp_rqt="'"+test[j]
                else:
                    tmp_rqt=tmp_rqt+"','"+test[j]

            tmp_rqt=tmp_rqt+"'"

            requete=requete+" "+filtre_op[i]+" "+filtre_var[i]+" in [ "+ tmp_rqt +" ] "

        df_tmp=df.query(requete)

    else:

        df_tmp=df

    # -----------------------
    # FILTRE DATE CORRIGÉ
    # -----------------------

    df_tmp = df_tmp[
        (df_tmp['dateheure'] >= start_date) &
        (df_tmp['dateheure'] < end_date + timedelta(days=1))
    ]

    df_tmp['date0']=df_tmp['dateheure']
    df_tmp['id']=df_tmp['id']

    global df_etape0
    df_etape0=df_tmp

    # -----------------------
    # RELATION STRICT
    # -----------------------

    df_relation=df_etape0[['idt_grp_cli','id','datefinal']]

    df_relation.sort_values(by=['idt_grp_cli','datefinal'], inplace=True)

    df_relation['idt_grp_cli_a'] = df_relation['idt_grp_cli'].shift(-1).fillna(0).astype(int)
    df_relation['id_a'] = df_relation['id'].shift(-1).fillna(0).astype(int)

    df_relation['good'] = np.where(df_relation['idt_grp_cli_a'] == df_relation['idt_grp_cli'], 'oui','non')

    df_relation['id_strict']=np.where(df_relation['good'] == 'oui',df_relation['id_a'] ,0)

    df_relation = df_relation.drop(columns=['idt_grp_cli_a','good','id_a'])

    df_relation = df_relation[['id','id_strict']]

    # -----------------------
    # RESULTAT
    # -----------------------

    global dataCA
    dataCA=[]

    ca_variable_analyse= df.columns.tolist()
    ca_variable_analyse.remove('idt_grp_cli')
    ca_variable_analyse.remove('datefinal')

    ca_visu_etape= range(1,nb_etape+1)

    ca_graphe_tunneldetransfo=ca_tunneldetransfo(nb_etape)

    fin= html.Div([
        html.Hr(),

        dbc.Row([
            dbc.Col(html.P(
                "Tunnel de transfo",
                style={'width':'50%','textAlign':'center','color':'#FFFFFF','font-size':'20px','font-weight':'bold'}
            ))
        ]),

        dbc.Row([
            dbc.Col(
                dcc.Graph(
                    figure=ca_graphe_tunneldetransfo,
                    id='graphCA_1'
                ),
                style={'width':'45%','background-color':'#084B66'}
            )
        ])
    ])

    return fin





